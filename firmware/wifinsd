void soapOK(const String& action) {
  String ns = "urn:schemas-upnp-org:service:AVTransport:1";
  String body =
    "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
    "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\" "
    "s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\">"
    "<s:Body>"
    "<u:" + action + "Response xmlns:u=\"" + ns + "\"/>"
    "</s:Body></s:Envelope>";
  server.send(200, "text/xml; charset=utf-8", body);
}

void soapRCOK(const String& action, const String& extra = "") {
  String ns = "urn:schemas-upnp-org:service:RenderingControl:1";
  String body =
    "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
    "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\" "
    "s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\">"
    "<s:Body>"
    "<u:" + action + "Response xmlns:u=\"" + ns + "\">" +
    extra +
    "</u:" + action + "Response>"
    "</s:Body></s:Envelope>";
  server.send(200, "text/xml; charset=utf-8", body);
}

String parseSoapAction(const String& body) {
  int bi = body.indexOf(":Body>");
  if (bi < 0) bi = body.indexOf("Body>");
  if (bi < 0) return "";
  int start = body.indexOf('<', bi + 5);
  if (start < 0) return "";
  start++;
  int colon   = body.indexOf(':', start);
  int space   = body.indexOf(' ',  start);
  int gt      = body.indexOf('>',  start);
  int nameEnd = min(space < 0 ? 9999 : space, gt < 0 ? 9999 : gt);
  String tag  = body.substring(start, nameEnd);
  if (colon >= start && colon < nameEnd) tag = tag.substring(tag.indexOf(':') + 1);
  return tag;
}

void handleAVT() {
  String body   = server.arg("plain");
  String action = parseSoapAction(body);
  if (action.length() == 0 && server.hasHeader("SOAPAction")) {
    String sa = server.header("SOAPAction");
    int h = sa.lastIndexOf('#'); if (h >= 0) action = sa.substring(h + 1);
    action.replace("\"", ""); action.replace(">", ""); action.trim();
  }
  Serial.println("AVT Action: [" + action + "]");

  if (action == "SetAVTransportURI") {
    String uri      = extractXml(body, "CurrentURI");
    String metadata = extractXml(body, "CurrentURIMetaData");
    String title    = extractXml(metadata, "dc:title");
    if (title.length() == 0) title = extractXml(metadata, "title");
    dmrCurrentURI     = uri;
    dmrCurrentTitle   = title.length() > 0 ? title : uri;
    dmrTransportState = "STOPPED";
    upnpMode = true;
    String resp =
      "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
      "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\" "
      "s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\">"
      "<s:Body><u:SetAVTransportURIResponse "
      "xmlns:u=\"urn:schemas-upnp-org:service:AVTransport:1\">"
      "</u:SetAVTransportURIResponse></s:Body></s:Envelope>";
    server.send(200, "text/xml; charset=utf-8", resp);
    return;
  }

  if (action == "Play") {
    if (dmrCurrentURI.length() > 0) {
      dmrPlay(dmrCurrentURI, dmrCurrentTitle);
      upnpMode = true;
    }
    String resp =
      "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
      "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\" "
      "s:encodingStyle=\"http://schemas.xmlsoap.org/soap/encoding/\">"
      "<s:Body><u:PlayResponse "
      "xmlns:u=\"urn:schemas-upnp-org:service:AVTransport:1\">"
      "</u:PlayResponse></s:Body></s:Envelope>";
    server.send(200, "text/xml; charset=utf-8", resp);
    return;
  }

  if (action == "Pause") { dmrPause(); soapOK(action); return; }
  if (action == "Stop")  { dmrStop();  soapOK(action); return; }

  if (action == "GetTransportInfo") {
    String ns = "urn:schemas-upnp-org:service:AVTransport:1";
    String resp =
      "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
      "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\">"
      "<s:Body><u:GetTransportInfoResponse xmlns:u=\"" + ns + "\">"
      "<CurrentTransportState>" + dmrTransportState + "</CurrentTransportState>"
      "<CurrentTransportStatus>OK</CurrentTransportStatus>"
      "<CurrentSpeed>1</CurrentSpeed>"
      "</u:GetTransportInfoResponse></s:Body></s:Envelope>";
    server.send(200, "text/xml; charset=utf-8", resp);
    return;
  }

  if (action == "GetPositionInfo") {
    String ns = "urn:schemas-upnp-org:service:AVTransport:1";
    String resp =
      "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
      "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\">"
      "<s:Body><u:GetPositionInfoResponse xmlns:u=\"" + ns + "\">"
      "<Track>1</Track><TrackDuration>0:00:00</TrackDuration>"
      "<TrackMetaData></TrackMetaData>"
      "<TrackURI>" + dmrCurrentURI + "</TrackURI>"
      "<RelTime>0:00:00</RelTime><AbsTime>0:00:00</AbsTime>"
      "<RelCount>0</RelCount><AbsCount>0</AbsCount>"
      "</u:GetPositionInfoResponse></s:Body></s:Envelope>";
    server.send(200, "text/xml; charset=utf-8", resp);
    return;
  }

  if (action == "GetMediaInfo") {
    String ns = "urn:schemas-upnp-org:service:AVTransport:1";
    String resp =
      "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
      "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\">"
      "<s:Body><u:GetMediaInfoResponse xmlns:u=\"" + ns + "\">"
      "<NrTracks>1</NrTracks><MediaDuration>0:00:00</MediaDuration>"
      "<CurrentURI>" + dmrCurrentURI + "</CurrentURI>"
      "<CurrentURIMetaData></CurrentURIMetaData>"
      "<NextURI>NOT_IMPLEMENTED</NextURI>"
      "<NextURIMetaData>NOT_IMPLEMENTED</NextURIMetaData>"
      "<PlayMedium>NETWORK</PlayMedium>"
      "<RecordMedium>NOT_IMPLEMENTED</RecordMedium>"
      "<WriteStatus>NOT_IMPLEMENTED</WriteStatus>"
      "</u:GetMediaInfoResponse></s:Body></s:Envelope>";
    server.send(200, "text/xml; charset=utf-8", resp);
    return;
  }

  soapOK(action);
}

