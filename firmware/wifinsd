void drawRoundBar(int x, int y, int w, int h, int r, bool filled) {
  if (filled) display.fillRoundRect(x, y, w, h, r, SSD1306_WHITE);
  else        display.drawRoundRect(x, y, w, h, r, SSD1306_WHITE);
}

void resetScroll() {
  if (upnpMode) {
    scrollName = dmrCurrentTitle.length() > 0 ? dmrCurrentTitle : dmrCurrentURI;
  } else if (totalTracks > 0) {
    scrollName = playlist[currentTrackIdx];
    if (scrollName.startsWith("/")) scrollName = scrollName.substring(1);
    String tmp = scrollName; tmp.toLowerCase();
    if (tmp.endsWith(".mp3")) scrollName = scrollName.substring(0, scrollName.length() - 4);
  } else {
    scrollName = "No track";
  }
  int textW = scrollName.length() * 6;
  if (textW <= 116) {
    scrollX = 6 + (116 - textW) / 2;  // short: center and hold
  } else {
    scrollX = SCREEN_WIDTH + 4;        // long: scroll in from right
  }
}

void showStatus() {
  display.clearDisplay();

  display.drawRoundRect(0, 0, SCREEN_WIDTH, SCREEN_HEIGHT, 6, SSD1306_WHITE);
  display.drawFastHLine(2, 14, 124, SSD1306_WHITE);
  display.drawFastHLine(2, 51, 124, SSD1306_WHITE);

  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setTextWrap(false);

  // Title bar
  display.setCursor(5, 4);
  display.print("PULSE-X");
  display.setCursor(70, 4);
  if (upnpMode) {
    display.print("UPnP DMR");
  } else {
    display.print(currentTrackIdx + 1);
    display.print("/");
    display.print(totalTracks);
  }

  // Middle top: icon + status (same line, y=20)
  display.setCursor(5, 20);
  if (isPlaying) {
    const char* frames[] = {">", ">>", ">>>", ">>", ">"};
    display.print(frames[animFrame % 5]);
  } else {
    display.print("||");
  }
  display.setCursor(30, 20);
  display.print(isPlaying ? "PLAY" : "PAUS");

  // Middle bottom: track name scroll (y=35)
  display.setCursor(scrollX, 35);
  display.print(scrollName);

  // Volume bar
  int barTotalW = 120;
  int barFillW  = constrain(map(volumePercent, 0, MAX_VOLUME, 0, barTotalW - 2), 0, barTotalW - 2);
  drawRoundBar(4, 53, barTotalW, 9, 3, false);
  if (barFillW > 0) drawRoundBar(5, 54, barFillW, 7, 3, true);

  display.display();
}

void showMsg(const char* msg) {
  display.clearDisplay();
  display.drawRoundRect(0, 0, SCREEN_WIDTH, SCREEN_HEIGHT, 6, SSD1306_WHITE);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(5, 4);
  display.print("PULSE-X");
  display.drawFastHLine(2, 14, 124, SSD1306_WHITE);
  display.setCursor(5, 24);
  display.print(msg);
  display.display();
}

void updateScroll() {
  if (scrollName.length() == 0) return;
  if (millis() - lastScrollTime < SCROLL_MS) return;
  lastScrollTime = millis();

  int textW = scrollName.length() * 6;
  if (textW <= 116) {
    showStatus();
    return;
  }
  scrollX -= 1;
  if (scrollX < -(textW + 8)) scrollX = SCREEN_WIDTH + 4;
  showStatus();
}

void updateAnim() {
  if (!isPlaying) return;
  if (millis() - lastAnimTime < ANIM_MS) return;
  lastAnimTime = millis();
  animFrame = (animFrame + 1) % 5;
  showStatus();
}

// ═════════════════════════════════════════════════════════════════════════════
//  PLAYBACK
// ═════════════════════════════════════════════════════════════════════════════

void applyBassBoost() {
  audio.setTone(4, 0, 0);
}

void playTrack(int idx) {
  if (totalTracks == 0) return;
  audio.connecttoFS(SD, playlist[idx].c_str());
  isPlaying = true;
  animFrame = 0;
  resetScroll();
  showStatus();
}

void dmrPlay(const String& uri, const String& title) {
  dmrCurrentURI     = uri;
  dmrCurrentTitle   = title;
  dmrTransportState = "PLAYING";
  audio.stopSong();
  delay(50);
  audio.connecttohost(uri.c_str());
  isPlaying = true;
  animFrame = 0;
  resetScroll();
  showStatus();
  Serial.println("DMR play: " + uri);
}

void dmrStop() {
  audio.stopSong();
  isPlaying         = false;
  dmrTransportState = "STOPPED";
  showStatus();
}

void dmrPause() {
  audio.pauseResume();
  isPlaying         = !isPlaying;
  dmrTransportState = isPlaying ? "PLAYING" : "PAUSED_PLAYBACK";
  showStatus();
}

