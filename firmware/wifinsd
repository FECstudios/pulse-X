void handleRC() {
  String body   = server.arg("plain");
  String action = parseSoapAction(body);
  if (action.length() == 0 && server.hasHeader("SOAPAction")) {
    String sa = server.header("SOAPAction");
    int h = sa.lastIndexOf('#'); if (h >= 0) action = sa.substring(h + 1);
    action.replace("\"", ""); action.replace(">", ""); action.trim();
  }
  if (action == "SetVolume") {
    int v = extractXml(body, "DesiredVolume").toInt();
    volumePercent = map(v, 0, 100, 0, MAX_VOLUME);
    audio.setVolume(volumePercent);
    showStatus();
    soapRCOK(action);
    return;
  }
  if (action == "GetVolume") {
    int v = map(volumePercent, 0, MAX_VOLUME, 0, 100);
    soapRCOK(action, "<CurrentVolume>" + String(v) + "</CurrentVolume>");
    return;
  }
  if (action == "SetMute") {
    String mute = extractXml(body, "DesiredMute");
    audio.setVolume(mute == "1" ? 0 : volumePercent);
    soapRCOK(action);
    return;
  }
  soapRCOK(action);
}

void handleCM() {
  String body2  = server.arg("plain");
  String action = parseSoapAction(body2);
  if (action.length() == 0 && server.hasHeader("SOAPAction")) {
    String sa = server.header("SOAPAction");
    int h = sa.lastIndexOf('#'); if (h >= 0) action = sa.substring(h + 1);
    action.replace("\"", ""); action.replace(">", ""); action.trim();
  }
  String ns    = "urn:schemas-upnp-org:service:ConnectionManager:1";
  String extra = "";
  if (action == "GetProtocolInfo") {
    extra =
      "<SourceProtocolInfo></SourceProtocolInfo>"
      "<SinkProtocolInfo>"
      "http-get:*:audio/mpeg:*,"
      "http-get:*:audio/mp3:*,"
      "http-get:*:audio/flac:*,"
      "http-get:*:audio/wav:*,"
      "http-get:*:audio/ogg:*"
      "</SinkProtocolInfo>";
  }
  String resp =
    "<?xml version=\"1.0\" encoding=\"utf-8\"?>"
    "<s:Envelope xmlns:s=\"http://schemas.xmlsoap.org/soap/envelope/\">"
    "<s:Body><u:" + action + "Response xmlns:u=\"" + ns + "\">"
    + extra +
    "</u:" + action + "Response></s:Body></s:Envelope>";
  server.send(200, "text/xml; charset=utf-8", resp);
}

void handleSubscribe() {
  server.sendHeader("SID", "uuid:pulse-x-sub-001");
  server.sendHeader("TIMEOUT", "Second-1800");
  server.send(200, "text/plain", "");
}

