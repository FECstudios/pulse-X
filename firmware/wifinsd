void switchToSD() {
  upnpMode = false;
  audio.stopSong();
  dmrTransportState = "STOPPED";
  delay(50);
  playTrack(currentTrackIdx);
}

void switchToUPnP() {
  upnpMode  = true;
  audio.stopSong();
  isPlaying = false;
  dmrTransportState = "STOPPED";
  scrollName = "UPnP waiting...";
  scrollX    = 4;
  showStatus();
}

void checkButtons() {
  if (millis() - lastBtnTime < DEBOUNCE_MS) return;

  static bool upL=HIGH, dnL=HIGH, plL=HIGH, prL=HIGH, nxL=HIGH;

  bool up = digitalRead(BTN_VOL_UP);
  bool dn = digitalRead(BTN_VOL_DN);
  bool pl = digitalRead(BTN_PLAY);
  bool pr = digitalRead(BTN_PREV);
  bool nx = digitalRead(BTN_NEXT);

  bool changed = false;

  if (up==LOW && upL==HIGH) {
    volumePercent = min(MAX_VOLUME, volumePercent + 1);
    audio.setVolume(volumePercent);
    showStatus(); changed = true;
  } upL = up;

  if (dn==LOW && dnL==HIGH) {
    volumePercent = max(0, volumePercent - 1);
    audio.setVolume(volumePercent);
    showStatus(); changed = true;
  } dnL = dn;

  if (pl==LOW && plL==HIGH) {
    if (!upnpMode) switchToUPnP();
    else           switchToSD();
    changed = true;
  } plL = pl;

  if (!upnpMode) {
    if (pr==LOW && prL==HIGH) {
      currentTrackIdx = (currentTrackIdx - 1 + totalTracks) % totalTracks;
      playTrack(currentTrackIdx); changed = true;
    } prL = pr;

    if (nx==LOW && nxL==HIGH) {
      currentTrackIdx = (currentTrackIdx + 1) % totalTracks;
      playTrack(currentTrackIdx); changed = true;
    } nxL = nx;
  } else {
    if (pr==LOW && nx==LOW) {
      switchToSD(); changed = true;
      delay(400);
    }
    prL = pr; nxL = nx;
  }

  if (changed) lastBtnTime = millis();
}

// ═════════════════════════════════════════════════════════════════════════════
//  SETUP
// ═════════════════════════════════════════════════════════════════════════════

void setup() {
  Serial.begin(115200);
  delay(500);

  pinMode(BTN_VOL_UP, INPUT_PULLUP); pinMode(BTN_VOL_DN, INPUT_PULLUP);
  pinMode(BTN_PLAY,   INPUT_PULLUP); pinMode(BTN_PREV,   INPUT_PULLUP);
  pinMode(BTN_NEXT,   INPUT_PULLUP);

  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(400000);
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) while(1);
  display.setTextWrap(false);
  display.setRotation(2);
  showMsg("Starting...");

  SPI.begin(SPI_SCK, SPI_MISO, SPI_MOSI, SD_CS);
  delay(100);
  if (!SD.begin(SD_CS, SPI)) { showMsg("NO SD CARD!"); while(1); }
  File root = SD.open("/");
  scanFolder(root); root.close();

  audio.setPinout(I2S_BCLK, I2S_LRC, I2S_DOUT);
  audio.setVolume(volumePercent);
  applyBassBoost();

  showMsg("WiFi...");
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 30) { delay(500); tries++; }

  if (WiFi.status() != WL_CONNECTED) {
    showMsg("No WiFi, SD mode");
    delay(1500);
  } else {
    Serial.println("IP: " + WiFi.localIP().toString());
    udpSsdp.beginMulticast(IPAddress(239,255,255,250), SSDP_PORT);

    static const char* hdrs[] = {"SOAPAction","CALLBACK","NT","TIMEOUT","SID"};
    server.collectHeaders(hdrs, 5);
    server.on("/description.xml", HTTP_GET,  handleDescription);
    server.on("/avt_scpd.xml",    HTTP_GET,  handleAVTScpd);
    server.on("/rc_scpd.xml",     HTTP_GET,  handleScpd);
    server.on("/cm_scpd.xml",     HTTP_GET,  handleScpd);
    server.on("/avt_control",     HTTP_POST, handleAVT);
    server.on("/rc_control",      HTTP_POST, handleRC);
    server.on("/cm_control",      HTTP_POST, handleCM);
    server.on("/avt_event",       HTTP_ANY,  handleSubscribe);
    server.on("/rc_event",        HTTP_ANY,  handleSubscribe);
    server.on("/cm_event",        HTTP_ANY,  handleSubscribe);
    server.onNotFound([](){
      Serial.println("404: " + server.uri());
      server.send(404, "text/plain", "Not Found");
    });
    server.begin();
    ssdpAlive();
    lastSsdpTime = millis();

    String ipMsg = "IP:" + WiFi.localIP().toString();
    showMsg(ipMsg.c_str());
    delay(1500);
  }

  if (totalTracks > 0) {
    resetScroll();
    playSys("/0001.mp3");
  } else {
    showMsg("No MP3 found!");
  }
}

// ═════════════════════════════════════════════════════════════════════════════
//  LOOP
// ═════════════════════════════════════════════════════════════════════════════

void loop() {
  audio.loop();
  server.handleClient();
  handleSsdp();
  checkButtons();

  if (pendingEof) {
    pendingEof = false;
    if (!upnpMode) playTrack(currentTrackIdx);
  }

  if (WiFi.status() == WL_CONNECTED && millis() - lastSsdpTime > SSDP_INTERVAL_MS) {
    ssdpAlive();
    lastSsdpTime = millis();
  }

  if (!sysSoundPlaying) {
    updateScroll();
    updateAnim();
  }
}

// ═════════════════════════════════════════════════════════════════════════════
//  AUDIO CALLBACKS
// ═════════════════════════════════════════════════════════════════════════════

void audio_info(const char* info) { Serial.println(info); }

void audio_showstreamtitle(const char* info) {
  if (upnpMode && info && strlen(info) > 0) {
    dmrCurrentTitle = String(info);
    resetScroll();
  }
  Serial.print("TITLE: "); Serial.println(info);
}

void audio_bitrate(const char* info) { Serial.print("BITRATE: "); Serial.println(info); }
void audio_id3data(const char* info) { Serial.print("ID3: ");     Serial.println(info); }

void audio_eof_mp3(const char* info) {
  Serial.print("EOF: "); Serial.println(info);

  if (!startupDone) {
    startupDone     = true;
    sysSoundPlaying = false;
    if (!upnpMode && totalTracks > 0) playTrack(0);
    return;
  }
  if (sysSoundPlaying) {
    sysSoundPlaying = false;
    pendingEof = true;
    return;
  }
  if (!upnpMode && totalTracks > 0) {
    currentTrackIdx = (currentTrackIdx + 1) % totalTracks;
    pendingEof = true;
  }
  if (upnpMode) {
    dmrTransportState = "STOPPED";
    isPlaying = false;
    showStatus();
  }
}
