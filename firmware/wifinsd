String localIP() { return WiFi.localIP().toString(); }

void ssdpNotify(const char* nt, const char* nts, const char* usn) {
  String msg =
    "NOTIFY * HTTP/1.1\r\n"
    "HOST: 239.255.255.250:1900\r\n"
    "CACHE-CONTROL: max-age=1800\r\n"
    "LOCATION: http://" + localIP() + ":" + String(UPNP_PORT) + "/description.xml\r\n"
    "NT: "  + String(nt)  + "\r\n"
    "NTS: " + String(nts) + "\r\n"
    "SERVER: ESP32/1.0 UPnP/1.0 PULSE-X/1.0\r\n"
    "USN: " + String(usn) + "\r\n"
    "\r\n";
  udpSsdp.beginPacket(SSDP_ADDR, SSDP_PORT);
  udpSsdp.print(msg);
  udpSsdp.endPacket();
}

void ssdpAlive() {
  ssdpNotify("upnp:rootdevice", "ssdp:alive", DEVICE_UUID "::upnp:rootdevice");
  delay(50);
  ssdpNotify(DEVICE_UUID, "ssdp:alive", DEVICE_UUID);
  delay(50);
  ssdpNotify("urn:schemas-upnp-org:device:MediaRenderer:1", "ssdp:alive",
             DEVICE_UUID "::urn:schemas-upnp-org:device:MediaRenderer:1");
  delay(50);
  ssdpNotify("urn:schemas-upnp-org:service:AVTransport:1", "ssdp:alive",
             DEVICE_UUID "::urn:schemas-upnp-org:service:AVTransport:1");
  delay(50);
  ssdpNotify("urn:schemas-upnp-org:service:RenderingControl:1", "ssdp:alive",
             DEVICE_UUID "::urn:schemas-upnp-org:service:RenderingControl:1");
}

void ssdpByebye() {
  ssdpNotify("upnp:rootdevice", "ssdp:byebye", DEVICE_UUID "::upnp:rootdevice");
  ssdpNotify(DEVICE_UUID,       "ssdp:byebye", DEVICE_UUID);
  ssdpNotify("urn:schemas-upnp-org:device:MediaRenderer:1", "ssdp:byebye",
             DEVICE_UUID "::urn:schemas-upnp-org:device:MediaRenderer:1");
}

void ssdpReply(IPAddress dest, uint16_t port, const char* st) {
  String msg =
    "HTTP/1.1 200 OK\r\n"
    "CACHE-CONTROL: max-age=1800\r\n"
    "DATE: Thu, 01 Jan 2026 00:00:00 GMT\r\n"
    "EXT:\r\n"
    "LOCATION: http://" + localIP() + ":" + String(UPNP_PORT) + "/description.xml\r\n"
    "SERVER: ESP32/1.0 UPnP/1.0 PULSE-X/1.0\r\n"
    "ST: " + String(st) + "\r\n"
    "USN: " + String(DEVICE_UUID) + "::" + String(st) + "\r\n"
    "\r\n";
  udpSsdp.beginPacket(dest, port);
  udpSsdp.print(msg);
  udpSsdp.endPacket();
}

void handleSsdp() {
  int len = udpSsdp.parsePacket();
  if (len <= 0) return;
  char buf[512]; memset(buf, 0, sizeof(buf));
  udpSsdp.read(buf, sizeof(buf) - 1);
  String pkt(buf);
  if (pkt.indexOf("M-SEARCH") < 0) return;

  IPAddress from = udpSsdp.remoteIP();
  uint16_t  port = udpSsdp.remotePort();

  String st = "ssdp:all";
  int si = pkt.indexOf("ST:");
  if (si >= 0) {
    int ei = pkt.indexOf("\r\n", si);
    st = pkt.substring(si + 3, ei); st.trim();
  }

  auto replyIfMatch = [&](const char* target) {
    if (st == "ssdp:all" || st == target) {
      delay(random(50, 200));
      ssdpReply(from, port, target);
    }
  };
  replyIfMatch("upnp:rootdevice");
  replyIfMatch("urn:schemas-upnp-org:device:MediaRenderer:1");
  replyIfMatch("urn:schemas-upnp-org:service:AVTransport:1");
  replyIfMatch("urn:schemas-upnp-org:service:RenderingControl:1");
  replyIfMatch(DEVICE_UUID);
}

